<mujoco model="ur5e scene">
  <include file="ur5e/ur5e.xml"/>

  <statistic center="0.3 0 0.4" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="belt" rgba="0.04 0.05 0.055 1"/>
    <material name="belt_side" rgba="0.18 0.2 0.22 1"/>
    <material name="roller" rgba="0.45 0.48 0.5 1"/>
    <material name="factory_yellow" rgba="0.95 0.68 0.12 1"/>
    <material name="light_zone" rgba="0.05 0.65 0.18 0.35"/>
    <material name="heavy_zone" rgba="0.82 0.08 0.05 0.35"/>
    <model name="umi_gripper_model" file="new_gripper/2f85.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- 机械臂底座 -->
    <body name="pedestal" pos="0 0 0.125">
      <geom name="pedestal_geom" type="box" size="0.1 0.1 0.125" rgba="0.3 0.3 0.3 1"/>
    </body>

    <!-- Factory conveyor in front of the arm -->
    <body name="conveyor" pos="0.55 0 0.35">
      <geom name="conveyor_belt"
            type="box"
            size="0.14 0.82 0.025"
            material="belt"/>
      <geom name="conveyor_front_roller"
            type="cylinder"
            pos="0 0.84 0.015"
            quat="0.7071 0 0.7071 0"
            size="0.03 0.16"
            material="roller"/>
      <geom name="conveyor_back_roller"
            type="cylinder"
            pos="0 -0.84 0.015"
            quat="0.7071 0 0.7071 0"
            size="0.03 0.16"
            material="roller"/>
      <geom name="conveyor_frame"
            type="box"
            pos="0 0 -0.055"
            size="0.18 0.87 0.025"
            material="belt_side"/>
      <geom name="conveyor_leg_fl"
            type="box"
            pos="0.12 0.70 -0.20"
            size="0.018 0.018 0.15"
            material="belt_side"/>
      <geom name="conveyor_leg_fr"
            type="box"
            pos="-0.12 0.70 -0.20"
            size="0.018 0.018 0.15"
            material="belt_side"/>
      <geom name="conveyor_leg_bl"
            type="box"
            pos="0.12 -0.70 -0.20"
            size="0.018 0.018 0.15"
            material="belt_side"/>
      <geom name="conveyor_leg_br"
            type="box"
            pos="-0.12 -0.70 -0.20"
            size="0.018 0.018 0.15"
            material="belt_side"/>
    </body>

    <!-- Light package: green cube -->
    <body name="green_cube" pos="0.55 -0.36 0.405">
      <freejoint/>
      <geom name="green_cube_geom"
            type="box"
            size="0.03 0.03 0.03"
            mass="0.2"
            friction="1.2 0.01 0.001"
            rgba="0 1 0 1"/>
    </body>

    <!-- Medium package: blue cube -->
    <body name="blue_cube" pos="0.55 0.00 0.405">
      <freejoint/>
      <geom name="blue_cube_geom"
            type="box"
            size="0.03 0.03 0.03"
            mass="0.5"
            friction="1.2 0.01 0.001"
            rgba="0 0.2 1 1"/>
    </body>

    <!-- Heavy package: red cube -->
    <body name="red_cube" pos="0.55 0.36 0.405">
      <freejoint/>
      <geom name="red_cube_geom"
            type="box"
            size="0.03 0.03 0.03"
            mass="1.0"
            friction="1.2 0.01 0.001"
            rgba="1 0 0 1"/>
    </body>

    <!-- Sorting targets: arm-left for light packages, arm-right for heavy packages -->
    <site name="light_bin_site"
          pos="0.00 0.68 0.47"
          size="0.03"
          rgba="0 1 0 1"/>

    <site name="heavy_bin_site"
          pos="0.00 -0.68 0.47"
          size="0.03"
          rgba="1 0 0 1"/>
          
    <body name="light_bin" pos="0.00 0.68 0.34">
      <geom name="light_bin_geom"
            type="box"
            size="0.16 0.14 0.025"
            material="light_zone"/>
      <geom name="light_bin_back_wall"
            type="box"
            pos="0 0.15 0.045"
            size="0.17 0.012 0.06"
            rgba="0.05 0.5 0.16 1"/>
      <geom name="light_bin_front_wall"
            type="box"
            pos="0 -0.15 0.045"
            size="0.17 0.012 0.06"
            rgba="0.05 0.5 0.16 1"/>
    </body>

    <body name="heavy_bin" pos="0.00 -0.68 0.34">
      <geom name="heavy_bin_geom"
            type="box"
            size="0.16 0.14 0.025"
            material="heavy_zone"/>
      <geom name="heavy_bin_back_wall"
            type="box"
            pos="0 0.15 0.045"
            size="0.17 0.012 0.06"
            rgba="0.62 0.06 0.04 1"/>
      <geom name="heavy_bin_front_wall"
            type="box"
            pos="0 -0.15 0.045"
            size="0.17 0.012 0.06"
            rgba="0.62 0.06 0.04 1"/>
    </body>
  </worldbody>
  
</mujoco>
