<mujoco model="ur5e scene">
  <include file="ur5e.xml"/>

  <statistic center="0.3 0 0.4" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="table" pos="0.55 0 0.35">
      <geom name="table_top"
            type="box"
            size="0.45 0.35 0.03"
            rgba="0.6 0.4 0.25 1"/>
    </body>

    <!-- Light object: green cube -->
    <body name="green_cube" pos="0.45 0.00 0.43">
      <freejoint/>
      <geom name="green_cube_geom"
            type="box"
            size="0.025 0.025 0.025"
            mass="0.2"
            friction="1.2 0.01 0.001"
            rgba="0 1 0 1"/>
    </body>

    <!-- Medium object: blue cube -->
    <body name="blue_cube" pos="0.55 0.10 0.43">
      <freejoint/>
      <geom name="blue_cube_geom"
            type="box"
            size="0.025 0.025 0.025"
            mass="0.5"
            friction="1.2 0.01 0.001"
            rgba="0 0.2 1 1"/>
    </body>

    <!-- Heavy object: red cube -->
    <body name="red_cube" pos="0.55 -0.10 0.43">
      <freejoint/>
      <geom name="red_cube_geom"
            type="box"
            size="0.025 0.025 0.025"
            mass="1.0"
            friction="1.2 0.01 0.001"
            rgba="1 0 0 1"/>
    </body>

    <!-- Target sites for placing -->
    <site name="light_bin_site"
          pos="0.0 0.35 0.55"
          size="0.03"
          rgba="0 1 0 1"/>

    <site name="heavy_bin_site"
          pos="0.0 -0.35 0.55"
          size="0.03"
          rgba="1 0 0 1"/>
          
    <body name="light_bin" pos="0.0 0.35 0.38">
      <geom name="light_bin_geom"
            type="box"
            size="0.12 0.12 0.03"
            rgba="0 1 0 0.4"/>
    </body>

    <body name="heavy_bin" pos="0.0 -0.35 0.38">
      <geom name="heavy_bin_geom"
            type="box"
            size="0.12 0.12 0.03"
            rgba="1 0 0 0.4"/>
    </body>
  </worldbody>
  
</mujoco>
